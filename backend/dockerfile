# Use the official Node 18 image for building
FROM node:18-bullseye-slim AS builder

# Set working directory
WORKDIR /app

# Install build dependencies required by better-sqlite3
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    sqlite3 \
    libsqlite3-dev \
 && rm -rf /var/lib/apt/lists/*

# Copy package manifests and install all deps (including dev)
COPY package.json package-lock.json ./
RUN npm ci

# Copy TS config and source, then compile to JavaScript
COPY tsconfig.json ./
COPY . .
RUN npx tsc

# --------------------------------------------------------------------------------
# Final image: only runtime deps + compiled JS
# --------------------------------------------------------------------------------
FROM node:18-bullseye-slim AS runner
WORKDIR /app

# Copy only production deps
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy compiled output from builder
COPY --from=builder /app/dist ./dist

# (Optional) Copy your .env into the container, or pass env vars via `docker run -e`
# COPY --from=builder /app/.env .env

# Expose the port your Fastify server listens on
EXPOSE 3000

# Start the server
CMD ["node", "dist/server.js"]
